{
  "name": "chatgpt-thread-exporter",
  "version": "0.1.0",
  "description": "Local-first CLI for exporting ChatGPT shared-link threads to Markdown.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "bin": {
    "chatgpt-thread-exporter": "./dist/cli.js"
  },
  "files": [
